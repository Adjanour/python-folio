---
const projects = {
  "early learning": [
    {
      name: "FullStack",
      url: "https://github.com/Adjanour/FullStack",
      description: "One of my first projects. Built with friends while figuring out how programming works.",
    },
    {
      name: "python-2025",
      url: "https://github.com/Adjanour/python-2025",
      description: "Small experiments around probability and simulation. Nothing serious, just poking at ideas.",
    },
    {
      name: "dsa-boot",
      url: "https://github.com/Adjanour/dsa-boot",
      description: "Data structures and algorithms practice. The stuff you do to get better at the fundamentals.",
    },
  ],
  "application building": [
    {
      name: "django-project",
      url: "https://github.com/Adjanour/django-project",
      description: "Transcript management system built with Django. A real problem, a straightforward solution.",
    },
    {
      name: "bank-x",
      url: "https://github.com/Adjanour/bank-x",
      description: "My first Django API. Learned a lot about structuring backend code here.",
    },
    {
      name: "ask-me-api",
      url: "https://github.com/Adjanour/ask-me-api",
      description: "FAQ-style medical chatbot API. The kind of project that teaches you where your assumptions break.",
    },
  ],
  research: [
    {
      name: "ae-net",
      url: "https://github.com/Adjanour/ae-net",
      description: "Autoencoder-based approach for SQL injection attack detection. Exploring where ML fits into security.",
    },
    {
      name: "final year project",
      url: null,
      description:
        "Knowledge graph–constrained decoding. Exploring how structured representations can improve reasoning and reduce hallucination in language models. Still in progress.",
    },
  ],
  "open source": [
    {
      name: "easechaos",
      url: "https://github.com/EaseCHAOS/easechaos",
      description:
        "I maintain this. We built a tool that extracts exams and class timetables at UMaT. People actually use it.",
    },
  ],
  "production systems": [
    {
      name: "Orcta Technologies",
      url: null,
      description:
        "Python runs parts of the backend services in a last-mile delivery system we're building. Real traffic, real constraints.",
    },
  ],
};

const links = [
  { label: "adjarnor.dev", url: "https://adjarnor.dev" },
  { label: "studio.adjarnor.dev", url: "https://studio.adjarnor.dev" },
  { label: "orctatech.com", url: "https://orctatech.com" },
  { label: "docs.orctatech.com", url: "https://docs.orctatech.com" },
  { label: "go.orctatech.com", url: "https://go.orctatech.com" },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>adjarnor — python engineer</title>
    <meta name="description" content="Systems-focused Python engineer. Interested in backend architecture, simplicity, and reliability." />
    <meta property="og:title" content="adjarnor — python engineer" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://adjarnor.dev" />
    <meta property="og:image" content="https://adjarnor.dev/og-image.png" />
    <meta property="og:site_name" content="adjarnor.dev" />
    <meta property="og:description" content="Systems-focused Python engineer. Interested in backend architecture, simplicity, and reliability." />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:image" content="https://adjarnor.dev/og-image.png" />
    <style is:global>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: monospace;
        font-size: 14px;
        line-height: 1.7;
        max-width: 720px;
        margin: 0 auto;
        padding: 3rem 1.5rem;
        color: #222;
        background: #fff;
      }
      h1 {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: -0.02em;
      }
      h2 {
        font-size: 12px;
        margin: 3rem 0 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #999;
        font-weight: 500;
      }
      p { margin-bottom: 1rem; }
      ul { list-style: none; padding: 0; }
      li {
        padding: 0.75rem 0;
        border-bottom: 1px solid #eee;
      }
      li:last-child { border-bottom: none; }
      .project-name {
        font-weight: 700;
        font-size: 14px;
      }
      .project-desc {
        color: #555;
        margin-top: 0.2rem;
        font-size: 13px;
        line-height: 1.5;
      }
      a {
        color: #222;
        text-decoration: underline;
        text-decoration-color: #ccc;
        text-underline-offset: 3px;
        transition: text-decoration-color 0.15s;
      }
      a:hover { text-decoration-color: #222; }
      .links {
        margin: 1rem 0 0;
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
      }
      .links a {
        font-size: 13px;
        color: #555;
        text-decoration: none;
        border-bottom: 1px solid #ddd;
        padding-bottom: 2px;
      }
      .links a:hover {
        color: #222;
        border-color: #222;
      }
      .about {
        margin: 1rem 0 2.5rem;
        color: #444;
        font-size: 13px;
        line-height: 1.6;
        max-width: 600px;
      }
      .phase-note {
        color: #aaa;
        font-size: 12px;
        margin-top: 0.25rem;
        margin-bottom: 0.75rem;
      }
      .header-line {
        margin: 0.75rem 0 0;
        border: none;
        height: 1px;
        background: #eee;
      }
      .quote {
        margin-top: 4rem;
        padding-top: 1.5rem;
        border-top: 1px solid #eee;
        color: #999;
        font-size: 12px;
        font-style: italic;
      }
    </style>
  </head>
  <body>
    <h1>adjarnor <span style="font-size:11px;color:#bbb;font-weight:400;margin-left:0.25rem">GH</span></h1>
    <hr class="header-line" />

    <p class="about">
      Systems-focused Python engineer. Interested in backend architecture,
      simplicity, and reliability. Most of my work has grown out of building
      things with friends, contributing to open source, and solving real
      problems at my startup.
    </p>

    <div class="links">
      {links.map(l => <a href={l.url}>{l.label}</a>)}
    </div>

    {Object.entries(projects).map(([phase, items]) => (
      <>
        <h2>{phase}</h2>
        {phase === "early learning" && (
          <p class="phase-note">Projects from when I was learning how things work.</p>
        )}
        {phase === "application building" && (
          <p class="phase-note">Real problems, straightforward solutions.</p>
        )}
        {phase === "research" && (
          <p class="phase-note">Where Python meets curiosity.</p>
        )}
        {phase === "open source" && (
          <p class="phase-note">Code that other people actually use.</p>
        )}
        {phase === "production systems" && (
          <p class="phase-note">Code running under real constraints.</p>
        )}
        <ul>
          {items.map(p => (
            <li>
              <div class="project-name">
                {p.url ? <a href={p.url}>{p.name}</a> : p.name}
              </div>
              <div class="project-desc">{p.description}</div>
            </li>
          ))}
      </ul>
      </>
      ))}

    <div class="quote">
      "Smile, breathe and go slowly." — Thich Nhat Hanh
    </div>
  </body>
</html>
